#!/usr/bin/env bash
# agent-gemini — run the Gemini CLI as agent-hud
# Operator's shell stays as kevin; the agent process runs under agent-hud UID.
# Deployed to /opt/agents/bin/agent-gemini by hud-provision.sh
#
# -E preserves the invoker's environment (DATABASE_URL, HUD_AGENT_* per the
# emily blueprint's OQ-2 propagation contract); HOME=/srv/hud explicitly
# overrides whatever -E would otherwise leak through (e.g. /root when invoked
# from a root shell, or /home/kevin when invoked by the operator), forcing the
# CLI's config/cache dirs to resolve under agent-hud's real home — without
# this override the CLI tries to mkdir under the invoker's $HOME and fails
# with EACCES (Ticket 26).
#
# XDG_CONFIG_HOME/XDG_CACHE_HOME/XDG_DATA_HOME/XDG_STATE_HOME/XDG_RUNTIME_DIR
# redirect each CLI's runtime state into agent-hud's own subtree
# (/srv/hud/agent-runtime/, 700 agent-hud:hud) instead of the XDG defaults
# under $HOME=/srv/hud — which is owned hud:hud, mode 750 with no group-write
# bit, so agent-hud cannot mkdir into it. Per ADR-26060701-agent-hud-xdg-runtime:
# this keeps the tenant root's "one owner, no foreign dotfiles" invariant intact
# while giving agent-hud a place it actually owns to persist config, caches,
# OAuth tokens/credentials, and CLI history. These five vars are allow-listed
# in the sudoers env_keep entry in /etc/sudoers.d/hud-operator so `-E` carries
# them through the privilege change instead of sudo stripping them.
set -euo pipefail

AGENT_RUNTIME=/srv/hud/agent-runtime

exec sudo -u agent-hud -E \
  HOME=/srv/hud \
  XDG_CONFIG_HOME="${AGENT_RUNTIME}/config" \
  XDG_CACHE_HOME="${AGENT_RUNTIME}/cache" \
  XDG_DATA_HOME="${AGENT_RUNTIME}/data" \
  XDG_STATE_HOME="${AGENT_RUNTIME}/state" \
  XDG_RUNTIME_DIR="${AGENT_RUNTIME}/runtime" \
  gemini "$@"
