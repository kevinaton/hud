#!/usr/bin/env bash
# hud-where <tenant> — print root, db.path, and services for the named tenant
# Deployed to /opt/agents/bin/hud-where by hud-provision.sh
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: hud-where <tenant>" >&2
  exit 1
fi

tenant="$1"
manifest="/etc/hud/tenants/${tenant}.yml"

if [[ ! -f "${manifest}" ]]; then
  echo "ERROR: tenant '${tenant}' not found (no file at ${manifest})" >&2
  exit 1
fi

python3 - "${manifest}" <<'PYEOF'
import sys
import yaml

manifest_path = sys.argv[1]
with open(manifest_path) as f:
    t = yaml.safe_load(f)

print(f"root:     {t.get('root', '')}")
print(f"db.path:  {t.get('db', {}).get('path', '')}")
services = t.get('services', [])
for svc in services:
    print(f"service:  {svc}")
PYEOF
