{
  // HUD tailnet ACL — managed in Tailscale admin console (tailscale.com/admin/acls)
  // Source of truth is THIS FILE; paste into the JSON editor and save to apply.
  //
  // Tailnet: tail5e5324.ts.net
  // MCP URL: https://hud.tail5e5324.ts.net/
  //
  // Philosophy:
  //   - Hetzner (hud-mcp.service) is tagged tag:hud-mcp
  //   - Operator devices running Hermes are tagged tag:hermes-client
  //   - tag:hermes-client can reach tag:hud-mcp only (all ports; bearer auth gates at app layer)
  //   - Operator personal devices (autogroup:member) retain full access to all nodes
  //   - Default: deny unless explicitly accepted
  //
  // To add MacBook #2: assign tag:hermes-client in the admin console — no ACL change needed.

  "tagOwners": {
    "tag:hud-mcp":       ["autogroup:admin"],
    "tag:hermes-client": ["autogroup:admin"]
  },

  "grants": [
    {
      // Operator devices — full access to everything (SSH, web, etc.)
      "src": ["autogroup:member"],
      "dst": ["*"],
      "ip":  ["*"]
    },
    {
      // Hermes clients (MacBook #1, future #2) — reach Hetzner only.
      // Port restriction is enforced at the application layer (bearer token + ACL).
      "src": ["tag:hermes-client"],
      "dst": ["tag:hud-mcp"],
      "ip":  ["*"]
    }
  ]
}
