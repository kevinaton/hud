{
  // HUD tailnet ACL — managed in Tailscale admin console (tailscale.com/admin/acls)
  // Source of truth is THIS FILE; paste into the editor and save to apply.
  //
  // Philosophy:
  //   - Hetzner (hud-mcp.service) is tagged tag:hud-mcp
  //   - Operator devices running Hermes are tagged tag:hermes-client
  //   - Only port 7610 (MCP daemon) is reachable from hermes-client nodes
  //   - SSH, Caddy (443), and all other ports use separate rules owned by the operator
  //   - Default: deny unless explicitly accepted
  //
  // To add MacBook #2: assign tag:hermes-client in the admin console — no ACL change needed.

  "tagOwners": {
    "tag:hud-mcp":       ["autogroup:admin"],
    "tag:hermes-client": ["autogroup:admin"]
  },

  "acls": [
    {
      // Hermes clients (MacBook #1, MacBook #2, etc.) may reach the MCP daemon only.
      // Bearer auth + argon2id on the daemon provides the application-layer gate.
      "action": "accept",
      "src":    ["tag:hermes-client"],
      "dst":    ["tag:hud-mcp:7610"]
    },
    {
      // Operator (any logged-in user / autogroup:member) retains full access to all nodes.
      // This covers SSH, web UI, etc. from the operator's personal devices.
      "action": "accept",
      "src":    ["autogroup:member"],
      "dst":    ["*:*"]
    }
  ],

  "ssh": [],

  "tests": [
    {
      "src":    "tag:hermes-client",
      "dst":    "tag:hud-mcp:7610",
      "accept": true
    },
    {
      "src":    "tag:hermes-client",
      "dst":    "tag:hud-mcp:22",
      "accept": false
    },
    {
      "src":    "tag:hermes-client",
      "dst":    "tag:hud-mcp:443",
      "accept": false
    }
  ]
}
