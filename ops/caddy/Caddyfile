# Production Caddyfile — committed in MVP, deployed in Phase 1
# Based on plan/reference/caddy.md
# Validate locally: caddy validate --config ops/caddy/Caddyfile
#
# NOTE: Traffic is routed via Cloudflare Tunnel (ops/cloudflared/config.yml),
# NOT via direct A records + Caddy. This file is kept for reference only.
# Caddy is running on the server but is not currently in the active traffic path.

hud.kevinaton.com {
	reverse_proxy localhost:3000

	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	log {
		output stderr
		format json
	}
}
