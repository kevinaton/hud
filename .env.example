# HUD — Environment variables
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# In production (Phase 1), this file is encrypted with sops+age:
#   sops --encrypt --age <pubkey> .env > .env.enc
# See ops/sops/.sops.yaml for key configuration.
#
# DO NOT commit .env.local or any file with real secrets.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# Node environment: "development" | "production" | "test"
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLite database file path (strip the 'file:' prefix is handled in code).
# Local dev:   file:./data/hud.db
# Production:  file:/var/lib/hud/hud.db
DATABASE_URL=file:./data/hud.db

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# Set to "true" to allow new user sign-ups via /signup.
# Keep "true" during local dev; set to "false" in production after first user is created.
HUD_ALLOW_SIGNUP=true

# Name of the session cookie.
# Must match the __Host- prefix rules for production (Secure + Path=/ + no Domain).
SESSION_COOKIE_NAME=__Host-hud_session

# Session lifetime in days (sliding window).
SESSION_TTL_DAYS=30

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# Sentry DSN for error tracking. Leave empty to disable Sentry (no-op in dev).
# Get your DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=

# Minimum log level: "trace" | "debug" | "info" | "warn" | "error" | "fatal"
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

# Default timezone for cashflow period calculations (IANA timezone name).
DEFAULT_TIMEZONE=Asia/Manila

# Default currency code (ISO 4217).
DEFAULT_CURRENCY=PHP

# ---------------------------------------------------------------------------
# CSV Importer (scripts/import-cashflow.ts)
# ---------------------------------------------------------------------------

# Actor written to audit_log for importer runs. Defaults to "system".
# AUDIT_ACTOR=system

# ---------------------------------------------------------------------------
# Litestream (Phase 1 — production only)
# ---------------------------------------------------------------------------

# Cloudflare R2 credentials for Litestream replication.
# Obtain from Cloudflare dashboard → R2 → Manage R2 API tokens.
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# sops / age (Phase 1 — production secrets management)
# ---------------------------------------------------------------------------

# Path to the age private key file used by sops to decrypt secrets.
# Default: ~/.config/sops/age/keys.txt
# SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt
